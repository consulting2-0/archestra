# Platform container environment for the lite e2e harness (docker --env-file).
#
# Mirrors `archestra.env` in .github/values-ci.yaml (the Kind+Helm CI job).
# Keep the two in sync: chat.spec.ts silently skips providers whose base URL
# is not configured, so a provider added there but not here loses coverage
# without failing anything.
#
# Vault settings are deliberately absent: the lite environment runs the
# default DB-backed secrets manager; Vault specs live in the K8s CI job.

# Quickstart mode: single container with internal Postgres and an embedded
# Kind cluster (via the mounted docker socket) for the MCP orchestrator.
ARCHESTRA_QUICKSTART=true
# No spec in this environment exercises the skill sandbox, so skip the Dagger
# engine boot — this also lets CI run the -slim image (no dagger-engine.tar).
ARCHESTRA_CODE_RUNTIME_ENABLED=false

ENABLE_E2E_TEST_ENDPOINTS=true
ENABLE_TEST_MCP_SERVER=true
ARCHESTRA_ANALYTICS=disabled

# LLM provider base URLs -> WireMock sidecar (per-provider path prefixes)
ARCHESTRA_OPENAI_BASE_URL=http://e2e-tests-wiremock:8080/openai/v1
ARCHESTRA_ANTHROPIC_BASE_URL=http://e2e-tests-wiremock:8080/anthropic
ARCHESTRA_GEMINI_BASE_URL=http://e2e-tests-wiremock:8080/gemini
ARCHESTRA_COHERE_BASE_URL=http://e2e-tests-wiremock:8080/cohere
ARCHESTRA_CEREBRAS_BASE_URL=http://e2e-tests-wiremock:8080/cerebras/v1
ARCHESTRA_VLLM_BASE_URL=http://e2e-tests-wiremock:8080/vllm/v1
ARCHESTRA_OLLAMA_BASE_URL=http://e2e-tests-wiremock:8080/ollama/v1
ARCHESTRA_GROQ_BASE_URL=http://e2e-tests-wiremock:8080/groq/v1
ARCHESTRA_XAI_BASE_URL=http://e2e-tests-wiremock:8080/xai/v1
ARCHESTRA_OPENROUTER_BASE_URL=http://e2e-tests-wiremock:8080/openrouter/api/v1
ARCHESTRA_ZHIPUAI_BASE_URL=http://e2e-tests-wiremock:8080/zhipuai/v4
ARCHESTRA_MISTRAL_BASE_URL=http://e2e-tests-wiremock:8080/mistral/v1
ARCHESTRA_BEDROCK_BASE_URL=http://e2e-tests-wiremock:8080/bedrock
ARCHESTRA_PERPLEXITY_BASE_URL=http://e2e-tests-wiremock:8080/perplexity/v1
ARCHESTRA_DEEPSEEK_BASE_URL=http://e2e-tests-wiremock:8080/deepseek
ARCHESTRA_GITHUB_COPILOT_BASE_URL=http://e2e-tests-wiremock:8080/github-copilot
ARCHESTRA_GITHUB_COPILOT_TOKEN_EXCHANGE_URL=http://e2e-tests-wiremock:8080/github/copilot_internal/v2/token
ARCHESTRA_MICROSOFT_365_COPILOT_BASE_URL=http://e2e-tests-wiremock:8080/microsoft-365-copilot
ARCHESTRA_MICROSOFT_365_COPILOT_AUTH_BASE_URL=http://e2e-tests-wiremock:8080/microsoft-login
ARCHESTRA_MICROSOFT_365_COPILOT_CLIENT_ID=e2e-test-client-id
ARCHESTRA_MINIMAX_BASE_URL=http://e2e-tests-wiremock:8080/minimax/v1
ARCHESTRA_AZURE_OPENAI_BASE_URL=http://e2e-tests-wiremock:8080/azure/openai/deployments/test-deployment
ARCHESTRA_AZURE_OPENAI_API_VERSION=2024-02-01

# Chat API keys (chat routes require a key to be present)
ARCHESTRA_CHAT_OPENAI_API_KEY=test-key
ARCHESTRA_CHAT_ANTHROPIC_API_KEY=test-key
ARCHESTRA_CHAT_GEMINI_API_KEY=test-key
ARCHESTRA_CHAT_COHERE_API_KEY=test-key
ARCHESTRA_CHAT_CEREBRAS_API_KEY=test-key
ARCHESTRA_CHAT_VLLM_API_KEY=test-key
ARCHESTRA_CHAT_OLLAMA_API_KEY=test-key
ARCHESTRA_CHAT_GROQ_API_KEY=test-key
ARCHESTRA_CHAT_XAI_API_KEY=test-key
ARCHESTRA_CHAT_OPENROUTER_API_KEY=test-key
ARCHESTRA_CHAT_ZHIPUAI_API_KEY=test-key
ARCHESTRA_CHAT_MISTRAL_API_KEY=test-key
ARCHESTRA_CHAT_BEDROCK_API_KEY=test-key
ARCHESTRA_CHAT_PERPLEXITY_API_KEY=test-key
ARCHESTRA_CHAT_DEEPSEEK_API_KEY=test-key
ARCHESTRA_CHAT_GITHUB_COPILOT_API_KEY=test-key
ARCHESTRA_CHAT_MINIMAX_API_KEY=test-key
ARCHESTRA_CHAT_AZURE_OPENAI_API_KEY=test-key

ARCHESTRA_METRICS_SECRET=foo-bar
ARCHESTRA_FRONTEND_URL=http://localhost:3000
ARCHESTRA_AUTH_SECRET=e2e-auth-secret-must-be-32-chars-long

# Enterprise license flags (required for the .ee specs)
ARCHESTRA_ENTERPRISE_LICENSE_ACTIVATED=true
ARCHESTRA_ENTERPRISE_LICENSE_FULL_WHITE_LABELING=true
ARCHESTRA_ENTERPRISE_LICENSE_KNOWLEDGE_BASE_ACTIVATED=true

# Beta feature gates exercised by the suite
ARCHESTRA_KNOWLEDGE_BASE_AUTO_SYNC_PERMISSIONS_ENABLED=true

ARCHESTRA_AUTH_RATE_LIMIT_DISABLED=true

# Keycloak sidecar as trusted origin (OIDC discovery URL validation):
# the docker network name the backend resolves, and the host-published URL
# that appears in OIDC discovery documents.
ARCHESTRA_AUTH_ADDITIONAL_TRUSTED_ORIGINS=http://e2e-tests-keycloak:8080,http://localhost:30081
